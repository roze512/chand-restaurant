generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Order {
  id           Int      @id @default(autoincrement())
  customerName String
  phone        String
  orderType    String
  address      String
  items        Json
  total        Int
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
}